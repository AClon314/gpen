{
  "manifest_version": 3,
  "name": "GPen",
  "version": "0.0.1",
  "description": "Grease Pencil core demo powered by Zig WASM.",
  "action": {
    "default_title": "GPen"
  },
  "permissions": [],
  "host_permissions": [
    "<all_urls>"
  ],
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "sidepanel.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "gpen_wasm.wasm",
        "sidepanel.css"
      ],
      "matches": [
        "<all_urls>"
      ]
    }
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self' 'wasm-unsafe-eval'; object-src 'self';"
  }
}